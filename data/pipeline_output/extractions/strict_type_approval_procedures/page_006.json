        "y1": 1230,
        "x2": 1476,
        "y2": 1414
      },
      "confidence": null,
      "language": "ara",
      "table_data": null,
      "crop_path": "crops/strict_type_approval_procedures/page_006/strict_type_approval_procedures_p006_b04_text.png"
    },
    {
