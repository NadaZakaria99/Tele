    {
      "block_id": "user_rights_regulations_p007_b08",
      "block_type": "header",
      "text": "المادة (١٢) الإيقاف المؤقت للخدمة",
      "bbox": {
        "x1": 1694,
        "y1": 735,
        "x2": 2169,
        "y2": 777
      },
      "confidence": null,
      "language": "ara",
