    },
    {
      "block_id": "user_rights_regulations_p007_b09",
      "block_type": "text",
      "text": "تلتزم الشركات بعدم إجراء وقف مؤقت للخدمة بناء على طلب المشترك إلا بعد الحصول على موافقة كتابية منه شخصياً أو عن طريق مكاملة صوتية مسجلة بشرط أن يكون اتصال المشترك من نفس رقم الخط الذي يريد وقف الخدمة عليه، وفي جميع الأحوال يجب تسجيل تحقيق الشخصية للعمل ورقمه القومي.",
      "bbox": {
        "x1": 84,
        "y1": 807,
        "x2": 2176,
        "y2": 892
      },
      "confidence": null,
