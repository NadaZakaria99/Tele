    {
      "block_id": "user_rights_regulations_p007_b05",
      "block_type": "header",
      "text": "المادة (١١) أعمال الصيانة والتحديثات المخطط لها",
      "bbox": {
        "x1": 1521,
        "y1": 455,
        "x2": 2160,
        "y2": 502
      },
      "confidence": null,
      "language": "ara",
      "table_data": null,
      "crop_path": "crops/user_rights_regulations/page_007/user_rights_regulations_p007_b05_header.png"
    },
    {
      "block_id": "user_rights_regulations_p007_b06",
      "block_type": "text",
      "text": "في حالة وجود أعمال صيانة أو تحديثات على الشبكات الخاصة بالشركات المرخص لها تؤثر على جودة الخدمة أو تتسبب في انقطاع أو تعطيل للخدمة تلتزم الشركات بالإبصار المسبق للمستخدمين بمدة يحددها الجهاز قبل الموعد المقرر لإجراء الصيانة أو التحديثات والمدة التي ستستغرقها، مع مراعاة أن تكون أعمال الصيانة والتحديثات المخطط لها خارج أوقات الخروبة (أثناء فترات انخفاض الحركة على الشبكة).",
      "bbox": {
        "x1": 84,
        "y1": 532,
        "x2": 2176,
        "y2": 658
      },
      "confidence": null,
      "language": "ara",
