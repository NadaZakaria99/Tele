    {
      "block_id": "user_rights_regulations_p006_b05",
      "block_type": "header",
      "text": "المادة (٨) التعريف",
      "bbox": {
        "x1": 1887,
        "y1": 526,
        "x2": 2153,
        "y2": 569
      },
      "confidence": null,
