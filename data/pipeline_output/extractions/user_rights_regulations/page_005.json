      "block_id": "user_rights_regulations_p005_b02",
      "block_type": "header",
      "text": "المادة (٣) نموذج العقد",
      "bbox": {
        "x1": 1842,
        "y1": 273,
        "x2": 2169,
        "y2": 317
      },
      "confidence": null,
