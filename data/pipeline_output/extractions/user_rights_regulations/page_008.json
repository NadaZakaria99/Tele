    {
      "block_id": "user_rights_regulations_p008_b03",
      "block_type": "text",
      "text": "تلتزم الشركات المرخص لها بما يلي:",
      "bbox": {
        "x1": 1787,
        "y1": 349,
        "x2": 2178,
        "y2": 389
      },
