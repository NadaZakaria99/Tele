    {
      "block_id": "user_rights_regulations_p012_b03",
      "block_type": "header",
      "text": "المادة (٢١) عدم الوفاء بالقواعد الماثلة",
      "bbox": {
        "x1": 1640,
        "y1": 343,
        "x2": 2172,
        "y2": 388
      },
      "confidence": null,
      "language": "ara",
