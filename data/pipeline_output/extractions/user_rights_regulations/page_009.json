    {
      "block_id": "user_rights_regulations_p009_b07",
      "block_type": "header",
      "text": "المادة (١٨) الشكاوى وخدمة العملاء",
      "bbox": {
        "x1": 1665,
        "y1": 902,
        "x2": 2169,
        "y2": 947
      },
      "confidence": null,
      "language": "ara",
