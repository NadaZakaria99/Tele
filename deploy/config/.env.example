# =============================================================================
# NBE Knowledge Assistant — Environment File (NVIDIA API Edition)
# =============================================================================
# Copy this file to deploy/config/.env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── NVIDIA / NGC ──────────────────────────────────────────────────────────────
# Used for ALL model calls (embedding, reranking, LLM) via integrate.api.nvidia.com
# and to authenticate the Chandra OCR-2 extraction container.
# Get your key at: https://ngc.nvidia.com/ → API Key
NGC_API_KEY=your_ngc_api_key_here

# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for extraction_service to download Chandra OCR-2 (gated model).
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# ── Data Directories ──────────────────────────────────────────────────────────
# DATA_DIR: Where the pipeline stores its output (page images, OCR JSONs,
#           crops, SQLite catalog). Must be an ABSOLUTE path on the host.
#           Docker bind-mount volumes require absolute paths.
DATA_DIR=/path/to/your/data

# PDF_SOURCE_DIR: The folder on YOUR machine that contains the source PDFs.
#                Used only by scripts/upload_pdfs.py — NOT mounted into Docker.
PDF_SOURCE_DIR=/path/to/your/pdfs

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── Milvus ────────────────────────────────────────────────────────────────────
MILVUS_COLLECTION=nbe_documents

# ── Extraction Service ────────────────────────────────────────────────────────
# Max pixel dimension for OCR inference.
# Lower to 1400 if you get CUDA out-of-memory errors.
MAX_INFERENCE_DIM=2000

# ── LLM Model ────────────────────────────────────────────────────────────────
# Served via NVIDIA API — no local download needed.
LLM_MODEL=meta/llama-3.1-8b-instruct

# ── Re-ingestion Policy ───────────────────────────────────────────────────────
# "replace" = delete doc vectors before re-indexing (safe re-run)
# "skip"    = do nothing if doc_id already exists
REINGESTION_POLICY=replace
