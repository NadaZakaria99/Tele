# RAG Service — Environment Variables
# Copy this to .env and fill in required values.

# ── NIM Endpoints (local containers) ─────────────────────────────────────────
NVIDIA_API_KEY=no-key-needed-for-local-nim
INFERENCE_BASE_URL=http://nim-llm:8000/v1
EMBEDDING_BASE_URL=http://nim-embedding:8000/v1
RERANK_BASE_URL=http://nim-rerank:8000/v1
SAFETY_BASE_URL=http://nim-safety:8000/v1

# ── Models ────────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2
RERANK_MODEL=nvidia/llama-3.2-nv-rerankqa-1b-v2
LLM_MODEL=meta/llama-3.1-8b-instruct
SAFETY_MODEL=nvidia/llama-3.1-nemoguard-8b-content-safety
TOPIC_MODEL=nvidia/llama-3.1-nemoguard-8b-topic-control

# ── Milvus ────────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=nbe_documents

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=768

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8002
LOG_LEVEL=info
