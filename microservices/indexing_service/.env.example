# Indexing Service — Environment Variables
# Copy this to .env and fill in required values.

# ── NIM Endpoints (local containers) ─────────────────────────────────────────
INFERENCE_BASE_URL=http://nim-embedding:8000/v1
NVIDIA_API_KEY=no-key-needed-for-local-nim
EMBEDDING_MODEL=nvidia/llama-3.2-nv-embedqa-1b-v2

# ── Milvus ────────────────────────────────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=nbe_documents

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CROPS=nbe-crops
MINIO_BUCKET_PAGES=nbe-page-images

# ── Paths (inside container / shared volume) ──────────────────────────────────
CATALOG_DB_PATH=/data/pipeline_output/catalog.db
DATA_DIR=/data
PIPELINE_OUTPUT_DIR=/data/pipeline_output

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50
REINGESTION_POLICY=replace

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
