# Extraction Service — Environment Variables
# Copy this to .env and fill in the required values.

# ── Required ──────────────────────────────────────────────────────────────────
# HuggingFace access token (model datalab-to/chandra-ocr-2 is gated)
HF_TOKEN=hf_your_token_here

# ── Optional overrides (defaults shown) ───────────────────────────────────────
CHANDRA_MODEL_ID=datalab-to/chandra-ocr-2
MAX_INFERENCE_DIM=2000
CROP_PADDING_PX=8
OUTPUT_DIR=/data/pipeline_output

# URL of the indexing service (used to auto-forward results after extraction)
# Set to empty string to disable auto-forwarding
INDEXING_SERVICE_URL=http://indexing_service:8001

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
